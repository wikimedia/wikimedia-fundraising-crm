<?xml version="1.0"?>
<extension key="org.wikimedia.systemtools" type="module">
  <file>systemtools</file>
  <name>Home for WMF helpers</name>
  <description>Tools to diagnose queries</description>
  <license>AGPL-3.0</license>
  <maintainer>
    <author>eileenmcnaughton</author>
    <email>emcnaughton@wikimedia.org</email>
  </maintainer>
  <urls>
    <url desc="Main Extension Page">https://docs.civicrm.org/system-tools/en/latest/</url>
    <url desc="Documentation">https://docs.civicrm.org/system-tools/en/latest/</url>
    <url desc="Support">https://lab.civicrm.org/extensions/systemtools/-/issues</url>
    <url desc="Licensing">http://www.gnu.org/licenses/agpl-3.0.html</url>
  </urls>
  <releaseDate>2026-06-01</releaseDate>
  <version>1.2</version>
  <develStage>stable</develStage>
  <compatibility>
    <ver>6.13</ver>
  </compatibility>
  <smarty_compatibility>
    <ver>5.0</ver>
  </smarty_compatibility>
  <php_compatibility>
    <ver>8.1</ver>
    <ver>8.2</ver>
    <ver>8.3</ver>
    <ver>8.4</ver>
  </php_compatibility>
  <comments>Tools to help analyse queries</comments>
  <civix>
    <namespace>CRM/Systemtools</namespace>
    <format>25.10.2</format>
  </civix>
  <classloader>
    <psr4 prefix="Civi\" path="Civi"/>
  </classloader>
  <mixins>
    <mixin>scan-classes@1.0.0</mixin>
  </mixins>
</extension>
