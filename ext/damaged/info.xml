<?xml version="1.0"?>
<extension key="damaged" type="module">
  <file>damaged</file>
  <name>Smashpig Damaged</name>
  <description>Searchkit display for the Smashpig Damaged table</description>
  <license>AGPL-3.0</license>
  <maintainer>
    <author>Damilare Adedoyin</author>
    <email>dadedoyin@wikimedia.org</email>
  </maintainer>
  <urls>
    <url desc="Main Extension Page">http://FIXME</url>
    <url desc="Documentation">http://FIXME</url>
    <url desc="Support">http://FIXME</url>
    <url desc="Licensing">http://www.gnu.org/licenses/agpl-3.0.html</url>
  </urls>
  <releaseDate>2022-10-18</releaseDate>
  <version>1.1</version>
  <develStage>stable</develStage>
  <compatibility>
    <ver>6.10</ver>
  </compatibility>
  <smarty_compatibility>
    <ver>5.0</ver>
  </smarty_compatibility>
  <php_compatibility>
    <ver>8.1</ver>
    <ver>8.2</ver>
    <ver>8.3</ver>
    <ver>8.4</ver>
    <ver>8.5</ver>
  </php_compatibility>
  <comments>This is a new, undeveloped module</comments>
  <requires>
    <ext>org.wikimedia.smashpig</ext>
  </requires>
  <classloader>
    <psr4 prefix="Civi\" path="Civi"/>
    <psr0 prefix="CRM_" path="."/>
  </classloader>
  <civix>
    <namespace>CRM/Damaged</namespace>
    <format>25.10.2</format>
  </civix>
  <mixins>
    <mixin>mgd-php@2.0.0</mixin>
    <mixin>setting-php@1.0.0</mixin>
    <mixin>menu-xml@1.0.0</mixin>
    <mixin>ang-php@1.0.0</mixin>
    <mixin>entity-types-php@2.0.0</mixin>
    <mixin>smarty@1.0.3</mixin>
    <mixin>scan-classes@1.0.0</mixin>
  </mixins>
  <upgrader>CiviMix\Schema\Damaged\AutomaticUpgrader</upgrader>
</extension>
